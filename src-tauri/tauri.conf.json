{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Classic Tetris Desktop",
  "version": "0.1.0",
  "identifier": "com.pchemguy.classic.tetris.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Classic Tetris Desktop",
        "width": 1280,
        "height": 960,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.ico"
    ],
    "targets": "all"
  }
}