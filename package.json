{
  "name": "classic-browser-tetris",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -s first \"npm run dev:web -- --host 127.0.0.1 --port 4173\" \"npm run dev:electron:build\" \"npm run dev:electron:start\"",
    "dev:web": "vite",
    "dev:electron:build": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron:start": "wait-on tcp:127.0.0.1:4173 dist-electron/electron/main.js && node ./scripts/dev-electron.mjs",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "tsc --noEmit && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "dist:win": "npm run build:renderer && npm run build:electron && electron-builder --win portable",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^37.10.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "wait-on": "^9.0.3"
  }
}
